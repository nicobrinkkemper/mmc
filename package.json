{
  "name": "mmc",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "homepage": "https://mmcelebration.com",
  "scripts": {
    "dev:ssr": "vite",
    "dev:rsc": "NODE_OPTIONS='--conditions=react-server' vite",
    "lint": "eslint ./src --fix",
    "serve": "node dist/server/dev-server.mjs",
    "serve-gh": "export PUBLIC_URL=/mmc; node dist/server/dev-server.mjs",
    "build": "NODE_OPTIONS='--conditions react-server' vite build --app",
    "build:app": "vite build --app",
    "build:prod": "npm run env:prod -- vite build --app",
    "build:gh": "PUBLIC_ORIGIN='https://nicobrinkkemper.github.io' BASE_URL='/mmc/' NODE_ENV=production GITHUB_ACTIONS=true NODE_OPTIONS='--conditions react-server' vite build --app",
    "build:preview": "npm run env:preview -- vite build --app",
    "build:dev": "vite build --app",
    "debug-build": "NODE_ENV=development npm run build",
    "export": "node dist/server/export.js",
    "build-mmc": "npm run startup && npm run build",
    "tsc": "rm -rf dist && npx tsc --project tsconfig.node.json && find src -name \"*.css\" -exec cp --parents {} dist/ \\;",
    "tsc-watch": "npx tsc --build --watch --incremental --force",
    "ssg": "run-s build server:crawl",
    "clean-install": "npm install vite-plugin-react-server react@experimental react-dom@experimental react-server-loader@experimental --save-dev",
    "patch": "patch",
    "link-dev": "npm link vite-plugin-react-server",
    "predeploy": "npm run build-gh",
    "deploy": "gh-pages -d build",
    "deploy:ftp": "node scripts/deploy-ftp-changed.mjs --yes",
    "deploy:ftp:check": "node scripts/deploy-ftp-changed.mjs --dry-run",
    "deploy:ftp:full": "node scripts/deploy-ftp.mjs",
    "deploy:ftp:backup": "node scripts/deploy-ftp-seed-backup.mjs",
    "test": "run-s startup react:test",
    "react:test": "vitest",
    "startup": "run-s startup:dev:*",
    "startup:dev": "run-s startup:dev:*",
    "startup:dev:compile": "npx tsc --project tsconfig.node.json",
    "startup:dev:run": "npm run env:dev -- node --import vite-plugin-react-server/register ./dist/startup/startup.mjs",
    "startup:prod": "run-s startup:prod:*",
    "startup:prod:compile": "npx tsc --project tsconfig.node.json",
    "startup:prod:run": "npm run env:prod -- node --import vite-plugin-react-server/register ./dist/startup/startup.mjs",
    "startup:gh": "run-s startup:gh:*",
    "startup:gh:compile": "npx tsc --project tsconfig.node.json",
    "startup:gh:run": "npm run env:gh -- node --import vite-plugin-react-server/register ./dist/startup/startup.mjs",
    "preview": "npm run build:preview && vite preview",
    "preview:prod": "npm run startup:prod && npm run build:prod && vite preview",
    "preview:gh": "npm run startup:gh && npm run build:gh && npm run env:gh -- vite preview",
    "oopsie-wsl": "find . -type f -name \"*:Zone.Identifier\" -exec rm {} \\;",
    "env:prod": "PUBLIC_ORIGIN='https://mmcelebration.com' BASE_URL='/' NODE_ENV=production",
    "env:gh": "PUBLIC_ORIGIN='https://nicobrinkkemper.github.io' BASE_URL='/mmc/' NODE_ENV=production GITHUB_ACTIONS=true",
    "env:preview": "PUBLIC_ORIGIN='http://localhost:4173' BASE_URL='/' NODE_ENV=production",
    "env:dev": "NODE_ENV=development"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=10"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {},
    "overrides": [
      {
        "files": [
          "src/**/*.ts?(x)",
          "startup/src/**/*.mts?(x)"
        ],
        "rules": {}
      }
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/connect-history-api-fallback": "^1.5.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/debug": "^4.1.13",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.7.0",
    "acorn-loose": "^8.5.2",
    "babel-plugin-react-compiler": "^19.0.0-beta-37ed2a7-20241206",
    "basic-ftp": "^6.0.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "connect-history-api-fallback": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "eslint-plugin-react-compiler": "^19.0.0-beta-37ed2a7-20241206",
    "express": "^4.22.2",
    "gh-pages": "^6.3.0",
    "happy-dom": "^15.11.7",
    "image-size": "^1.2.1",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "markdown-to-jsx": "^7.7.17",
    "npm-check-updates": "^17.1.18",
    "npm-run-all": "^4.1.5",
    "react": "0.0.0-experimental-99e86060-20260623",
    "react-dom": "0.0.0-experimental-99e86060-20260623",
    "react-server-loader": "0.0.0-experimental-99e86060-20260623",
    "sharp": "^0.35.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^6.4.3",
    "vite-css-modules": "^1.16.0",
    "vite-plugin-react-server": "^2.11.0",
    "vitest": "^3.2.6",
    "webpack-sources": "^3.5.0"
  },
  "include": [
    "src"
  ],
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "react-server-loader": "0.0.0-experimental-99e86060-20260623"
  },
  "dependencies": {
    "flag-icons": "^7.5.0"
  }
}
