# FTP deploy credentials. These are SECRETS — copy this file to
# `.env.local` (which is gitignored) and fill the values there.
# Do NOT put credentials in `.env`, that file is committed.
#
# The deploy script loads `.env` first, then overlays `.env.local`.
FTP_HOST=s101.etcserver.com
FTP_PORT=21
FTP_USER=geitje@mmcelebration.com
FTP_PASS=
# Remote root the host expects you to upload into. Duffy's note: "drill down to /www".
FTP_REMOTE_DIR=/www
# Local build output to mirror.
FTP_LOCAL_DIR=dist/static
# Use FTPS-explicit (recommended). Set to "false" only if the host rejects AUTH TLS.
FTP_SECURE=true
